## HiveMQ Cloud (MQTT over WebSocket for browsers)
#
# URL format (HiveMQ Cloud):
# - MUST be WSS for browsers
# - MUST include the /mqtt path
# - Example: wss://<your-cluster-host>:8884/mqtt
VITE_MQTT_URL=wss://YOUR_CLUSTER_HOST:8884/mqtt
VITE_MQTT_USERNAME=YOUR_USERNAME
VITE_MQTT_PASSWORD=YOUR_PASSWORD
VITE_MQTT_TOPIC_ALERTS=smartscan/alerts

